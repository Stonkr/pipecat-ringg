# Ringg AI STT credentials
RINGG_API_KEY=your-ringg-api-key
# Optional: override the Ringg API base URL (leave unset to use the SDK default)
# RINGG_BASE_URL=
# Optional: transcription language code (default: hi)
RINGG_LANGUAGE=hi

# Transport credentials for the example (Daily shown; only needed for the
# transport you choose when running example.py).
DAILY_API_KEY=your-daily-api-key
DAILY_SAMPLE_ROOM_URL=https://your-domain.daily.co/your-room
